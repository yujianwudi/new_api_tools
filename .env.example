# NewAPI Middleware Tool - Environment Configuration
#
# 推荐使用 deploy.sh 自动生成此文件
# 手动配置时，复制此文件为 .env 并修改

# 一键安装/部署脚本会先拉取目标 tag，再原子写入解析后的 repo@sha256 digest。
# 手动部署必须从发行页复制已核验的不可变 digest；留空时 Compose 会拒绝启动。
NEWAPI_TOOLS_IMAGE=

# ===========================================
# NewAPI 环境 (由 deploy.sh 自动检测)
# ===========================================

# NewAPI 容器名
NEWAPI_CONTAINER=new-api

# NewAPI Docker 网络名
NEWAPI_NETWORK=

# 直接写库安全开关：只有确认 NewAPI 的 REDIS_CONN_STRING 明确为空时才能设为 true。
# deploy.sh/install.sh 会自动检测；未检测到变量或值非空时保持 false，并阻止用户/Token 等写操作。
NEWAPI_REDIS_DISABLED=false

# 高风险批量不活跃用户删除兼容开关。旁路工具无法原子协调 NewAPI 在途请求、
# 异步 request_count、消费日志开关和日志保留期，默认必须保持 false。
# 仅在已停止入口、排空全部在途请求并核验消费日志完整性后临时设为 true；
# 操作完成后立即恢复 false。仍要求 NEWAPI_REDIS_DISABLED=true，优先使用 NewAPI 管理 API。
ALLOW_UNSAFE_BATCH_DELETE=false

# 高风险永久删除兼容开关。NewAPI 官方删除还会清理多种认证绑定，本工具无法跨版本安全覆盖。
# 默认 false；请优先通过 NewAPI 管理 API 永久删除。即使设 true，也要求 NEWAPI_REDIS_DISABLED=true。
ALLOW_UNSAFE_HARD_DELETE=false

# ===========================================
# 数据库配置 (由 deploy.sh 自动检测)
# ===========================================

# Go 版本推荐使用完整 DSN 字符串 (设置了 SQL_DSN 则忽略下面的分离配置)
# MySQL:  SQL_DSN=user:pass@tcp(host:3306)/dbname?charset=utf8mb4&parseTime=True
# PgSQL:  SQL_DSN=host=localhost port=5432 user=postgres password=xxx dbname=one-api sslmode=disable
SQL_DSN=

# 日志专用库连接串（可选）。NewAPI 的部分 fork 用 LOG_SQL_DSN 把 logs 表分离到
# 独立库；此时本工具需读取该库才能看到实时日志/流量，否则相关页面全为 0。
# 留空 = 日志查询回落主库（行为与上游一致）。建议用 ./setup-log-db.sh 自动检测生成。
LOG_SQL_DSN=

# 兼容旧版分离配置
# 数据库引擎: mysql 或 postgres
DB_ENGINE=postgres

# 数据库主机 (容器名或服务名)
DB_DNS=postgres

# 数据库端口 (MySQL: 3306, PostgreSQL: 5432)
DB_PORT=5432

# 数据库名
DB_NAME=new-api

# 数据库用户
DB_USER=postgres

# 数据库密码
DB_PASSWORD=

# 连接池配置（可选，默认 50 / 15）
# 如果 NewAPI 自身已占用大量 DB 连接，建议把 DB_MAX_OPEN_CONNS 调到 30 左右
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=15

# ===========================================
# Go 后端绑定地址（高级，通常不要改）
# ===========================================
# 默认 127.0.0.1：Go 进程只监听容器内 loopback，由同容器的 Nginx 反代到外部
# 改成 0.0.0.0：暴露 Go 后端到容器虚拟网卡（host 网络模式下会暴露到宿主机所有接口，有安全风险）
# 仅在你需要其他容器/工具直连 Go 后端 8000 端口调试时才改
# SERVER_HOST=127.0.0.1

# ===========================================
# 认证配置
# ===========================================

# 前端访问密码 (必填)
ADMIN_PASSWORD=

# 后端 API Key (必填，deploy.sh 会自动生成)
API_KEY=
# API Key 默认是 viewer；需要写操作时必须显式提升为 operator 或 admin。
API_KEY_ROLE=viewer

# JWT 密钥 (deploy.sh 会自动生成)
JWT_SECRET=

# JWT 过期时间 (小时)
JWT_EXPIRE_HOURS=24

# 浏览器跨域访问。留空表示只允许同源访问（推荐）。
# 如需跨域，填写逗号分隔的精确 HTTPS Origin，例如：
# CORS_ALLOWED_ORIGINS=https://ops.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
# 仅在确实需要跨域 Cookie/Authorization 且 Origin 完全受信时开启。
CORS_ALLOW_CREDENTIALS=false

# 登录防暴力破解：在统计窗口内达到失败次数后按指数退避。
LOGIN_MAX_ATTEMPTS=8
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_BACKOFF_BASE_MS=500
LOGIN_BACKOFF_MAX_SECONDS=30

# 公开模型状态接口资源限制。
PUBLIC_MODEL_MAX_BATCH=50
PUBLIC_MODEL_MAX_BODY_BYTES=16384
PUBLIC_MODEL_REQUESTS_PER_MINUTE=30

# Redemption creation financial guardrails in NewAPI quota units (500000 = US$1).
# Defaults cap one code at US$100 and one operation at US$1000. Keep them conservative.
REDEMPTION_MAX_QUOTA_PER_CODE=50000000
REDEMPTION_MAX_TOTAL_QUOTA=500000000

# 只有直接 TCP 对端命中此精确列表时，后端才解析 X-Forwarded-For。
# 合并镜像的内层 Nginx 走 loopback，因此默认信任 127.0.0.1/::1。
# 若宿主机还有一层反向代理，请追加内层 Nginx 实际看到的代理 IP（精确 /32 或 /128），
# 不要填写整个 172.16.0.0/12 等私网段。
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# ===========================================
# 服务配置
# ===========================================

# 前端端口 (默认: 1145)
FRONTEND_PORT=1145

# 前端端口绑定的网卡 (默认: 127.0.0.1，仅本机可达)
# 生产环境请保持 127.0.0.1，并在宿主机用 nginx / Caddy 反代到 HTTPS 域名：
#   server {
#     listen 443 ssl http2;
#     server_name stats.example.com;
#     location / {
#       proxy_pass http://127.0.0.1:1145;
#       proxy_set_header Host $host;
#       proxy_set_header X-Real-IP $remote_addr;
#       proxy_set_header X-Forwarded-For $remote_addr;
#       proxy_set_header X-Forwarded-Proto $scheme;
#     }
#   }
FRONTEND_BIND=127.0.0.1

# 时区
TIMEZONE=Asia/Shanghai

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# ===========================================
# 外部服务
# ===========================================

# NewAPI 内部地址 (用于API调用)
NEWAPI_BASEURL=

# NewAPI 管理 API 专用凭据。请创建独立管理员账号并限制其网络来源；
# 不要复用本工具的 API_KEY，也不要使用模型调用 Token。
NEWAPI_ADMIN_ACCESS_TOKEN=
NEWAPI_ADMIN_USER_ID=0

# Prometheus /metrics 使用独立 Bearer 凭据；留空时端点返回 404，不会公开指标。
OBSERVABILITY_TOKEN=
# 最新 NewAPI 日志超过该秒数时标记为 stale（仅诊断，不会因低流量自动判故障）。
LOG_FRESHNESS_MAX_SECONDS=900

# 本工具独立的旁路状态库；只保存审计、案件、价格和对账快照，不写入 NewAPI 表。
TOOL_STORE_PATH=./data/control-plane.db

# 默认只使用镜像内或手工挂载的、已验证 GeoIP 数据库。显式开启下载时仅
# 接受 v0.5.0 固定提交和 SHA-256；自动更新要求两个开关同时为 true。
GEOIP_AUTO_DOWNLOAD=false
GEOIP_AUTO_UPDATE=false

# ===========================================
# Redis 缓存配置
# ===========================================
# Redis 已默认启用，用于加速缓存恢复和查询性能

# Redis 密码 (无密码则留空)
REDIS_PASSWORD=
